rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(data) {
      return isSignedIn() && (data.userId == request.auth.uid || data.customerId == request.auth.uid);
    }

    function isAdmin() {
      // Primary hardcoded admin (fail-safe)
      let isPrimary = request.auth.token.email == "adityaofficial9918@gmail.com";
      return isSignedIn() && (isPrimary || request.auth.token.email in get(/databases/$(database)/documents/settings/global).data.adminEmails);
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // Settings: Global settings readable by all, writable by admin
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Menu Items: Publicly readable, Admin manageable
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Temporary permission for initial seeding (remove in full production)
      allow create: if true; 
    }

    // Tables: Publicly readable
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Anyone can create, only owners or admins can read/update
    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read: if true; 
      
      allow update: if isAdmin() || (
        // Regular customers can only update paymentStatus (e.g. after successful payment)
        incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'updatedAt'])
        && incoming().status == existing().status // Cannot change status
      );
      
      allow delete: if isAdmin();
    }

    function isValidOrder(data) {
      return data.tableId is string 
        && data.items is list 
        && data.total is number 
        && data.status in ['pending', 'confirmed', 'preparing', 'ready', 'served', 'cancelled']
        && data.items.size() > 0
        && data.customerId is string;
    }

    // Coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow create: if true; 
      allow update: if isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['isUsed']);
    }

    // Customer Insights / Users (for admin)
    match /users/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && userId == request.auth.uid);
    }
  }
}
