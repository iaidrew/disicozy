rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      let isPrimary = request.auth.token.email == "adityaofficial9918@gmail.com";
      return isSignedIn() && (isPrimary || request.auth.token.email in get(/databases/$(database)/documents/settings/global).data.adminEmails);
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- ENTITY VALIDATIONS ---
    function isValidOrder(data) {
      return data.tableId is string && data.tableId.size() < 100
        && data.customerId is string && data.customerId.size() < 100
        && data.items is list
        && data.total is number && data.total >= 0
        && data.status in ['pending', 'confirmed', 'preparing', 'ready', 'served', 'cancelled']
        && data.paymentStatus in ['unpaid', 'paid']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidLog(data) {
      return data.type is string && data.type.size() < 100
        && data.message is string && data.message.size() < 1000
        && data.timestamp == request.time;
    }

    // --- COLLECTION RULES ---

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow initial seeding
      allow create: if true; 
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read: if true; // Public tracking for customers via ID
      
      allow update: if (isAdmin() && (
        // Admin: Full control except immutables
        incoming().createdAt == existing().createdAt &&
        incoming().customerId == existing().customerId
      )) || (
        // Customer: Payment confirmation only
        incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'updatedAt']) &&
        incoming().status == existing().status &&
        incoming().paymentStatus == 'paid'
      );
      
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      // Read: Only admins can see audit trail and notifications
      allow read: if isAdmin();
      
      // Create: Anyone can create if it's an order event, otherwise admin only
      allow create: if (incoming().type == 'ORDER_CREATED' && isValidLog(incoming())) 
                    || (isAdmin() && isValidLog(incoming()));
      
      allow update, delete: if false; // Logs are immutable
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow customers to apply coupons by incrementing isUsed or similar if needed
      allow update: if isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['isUsed']) && incoming().isUsed == true);
    }

    match /users/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && userId == request.auth.uid);
    }
  }
}
